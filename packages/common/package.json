{
    "name": "@srvkit/common",
    "version": "0.1.1",
    "description": "A toolkit for building APIs",
    "keywords": [
        "srvkit",
        "srvx",
        "ts",
        "typescript",
        "js",
        "javascript"
    ],
    "homepage": "https://github.com/srvkit/srvkit",
    "bugs": "https://github.com/srvkit/srvkit/issues",
    "repository": {
        "type": "git",
        "url": "https://github.com/srvkit/srvkit.git",
        "directory": "packages/common"
    },
    "license": "MIT",
    "author": {
        "name": "Alpheus",
        "email": "contact@alphe.us"
    },
    "exports": {
        "./@types/options/complete": {
            "types": "./dist/@types/options/complete/index.d.ts",
            "import": "./dist/@types/options/complete/index.mjs",
            "require": "./dist/@types/options/complete/index.js"
        },
        "./*": {
            "types": "./dist/*.d.ts",
            "import": "./dist/*.mjs",
            "require": "./dist/*.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist"
    ],
    "dependencies": {
        "consola": "^3.4.0",
        "es-toolkit": "catalog:dep",
        "srvx": "~0.11.0",
        "ts-vista": "~0.2.3"
    }
}
