{
    "name": "@srvkit/rsbuild",
    "version": "0.1.0",
    "description": "A toolkit for building JavaScript server applications",
    "keywords": [
        "srvkit",
        "rsbuild",
        "srvx",
        "ts",
        "typescript",
        "js",
        "javascript"
    ],
    "homepage": "https://github.com/srvkit/srvkit",
    "bugs": "https://github.com/srvkit/srvkit/issues",
    "repository": {
        "type": "git",
        "url": "https://github.com/srvkit/srvkit.git",
        "directory": "packages/rsbuild"
    },
    "license": "MIT",
    "author": {
        "name": "Alpheus",
        "email": "contact@alphe.us"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./node": {
            "types": "./dist/node.d.ts",
            "import": "./dist/node.mjs",
            "require": "./dist/node.js"
        },
        "./plugin": {
            "types": "./dist/plugin.d.ts",
            "import": "./dist/plugin.mjs",
            "require": "./dist/plugin.js"
        },
        "./runtime": {
            "types": "./dist/runtime.d.ts",
            "import": "./dist/runtime.mjs",
            "require": "./dist/runtime.js"
        },
        "./package.json": "./package.json"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "dependencies": {
        "@srvkit/common": "workspace:~"
    },
    "devDependencies": {
        "@rsbuild/core": "catalog:dev"
    },
    "peerDependencies": {
        "@rsbuild/core": "catalog:peer"
    },
    "peerDependenciesMeta": {
        "@rsbuild/core": {
            "optional": true
        }
    }
}
